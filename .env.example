# Example environment variables for FastAPI project
# Copy this file to .env and fill in the actual values

# Database URL (e.g., for SQLite or PostgreSQL)
DATABASE_URL=sqlite:///database.db

# Secret key for JWT or sessions (generate a secure random string)
SECRET_KEY=your_secret_key_here

# API settings
API_TITLE=FastAPI App
API_DESCRIPTION=A FastAPI application with user management
API_VERSION=1.0.0

# Optional: External service URLs
# EMAIL_SERVICE_URL=https://api.emailservice.com
# REDIS_URL=redis://localhost:6379